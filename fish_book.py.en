# =============================================================
# 3-FRAME ANIMATION
# For complex arts — 3 identical frames (can be improved)
# =============================================================
def make_frames(art, eye_changes=None, detail_changes=None):
    """Creates 3 frames: original, with eye changes, with detail changes"""
    frames = [art[:]]  # Frame 1: original
    
    # Frame 2: change eyes
    frame2 = []
    for line in art:
        if eye_changes:
            for old, new in eye_changes:
                line = line.replace(old, new)
        frame2.append(line)
    frames.append(frame2)
    
    # Frame 3: change details
    frame3 = []
    for line in art:
        if detail_changes:
            for old, new in detail_changes:
                line = line.replace(old, new)
        frame3.append(line)
    frames.append(frame3)
    
    return frames

# Simple animations for fish
